# name: test/sql/meta.test
# description: Test the github_rest function against the /meta endpoint
# group: [sql]

require-env GITHUB_TOKEN

require github_client

require json

# The /meta endpoint returns a non-empty list of GitHub SSH keys
query I
SELECT count(*) > 0 FROM (
    SELECT UNNEST(body->>'$.ssh_keys[*]') AS ssh_key
    FROM github_rest('/meta')
);
----
true
