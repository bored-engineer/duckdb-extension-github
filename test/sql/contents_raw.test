# name: test/sql/contents_raw.test
# description: Test github_contents_raw fetching raw file content from a repository
# group: [sql]

require-env GITHUB_TOKEN

require github

statement ok
CREATE SECRET github (
    TYPE http,
    BEARER_TOKEN '${GITHUB_TOKEN}',
    SCOPE 'https://api.github.com'
);

# 3-arg: fetch from default branch, verify known content.
query I
SELECT contains(
    github_contents_raw('bored-engineer', 'duckdb-extension-github', 'LICENSE')::VARCHAR,
    'Permission is hereby granted'
);
----
true

# 4-arg with explicit ref.
query I
SELECT contains(
    github_contents_raw('bored-engineer', 'duckdb-extension-github', 'LICENSE', 'main')::VARCHAR,
    'Permission is hereby granted'
);
----
true

# 4-arg with empty string ref is equivalent to the 3-arg form.
query I
SELECT github_contents_raw('bored-engineer', 'duckdb-extension-github', 'LICENSE', '')
    = github_contents_raw('bored-engineer', 'duckdb-extension-github', 'LICENSE');
----
true

# 5-arg with explicit host and empty ref.
query I
SELECT contains(
    github_contents_raw('bored-engineer', 'duckdb-extension-github', 'LICENSE', '', 'api.github.com')::VARCHAR,
    'Permission is hereby granted'
);
----
true
