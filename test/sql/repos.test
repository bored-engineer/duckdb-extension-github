# name: test/sql/repos.test
# description: Test pagination by listing all repos owned by bored-engineer
# group: [sql]

require-env GITHUB_TOKEN

require github

require json

statement ok
CREATE SECRET github (
    TYPE http,
    BEARER_TOKEN '${GITHUB_TOKEN}',
    SCOPE 'https://api.github.com'
);

# bored-engineer has more than 100 public repositories, requiring at least 2 paginated requests.
# The array response yields one row per repository, so each row's data is a single repository object.
query I
SELECT count(*) > 100 FROM (
    SELECT json_transform(data, github_rest_type('repository')) AS r
    FROM github_rest('/users/bored-engineer/repos?per_page=100')
);
----
true
